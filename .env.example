APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

OPENAI_CONTENT_MODEL=gpt-5-mini
OPENAI_FILE_EXTRACTION_MODEL=gpt-5.4-mini
OPENAI_FILE_EXTRACTION_REASONING_EFFORT=low
OPENAI_FILE_EXTRACTION_TEXT_VERBOSITY=low
OPENAI_FILE_EXTRACTION_MAX_OUTPUT_TOKENS=12000

UNSPLASH_ACCESS_KEY=

MAXMIND_LICENSE_KEY=
MAXMIND_USER_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

BACKUP_DISKS=backups
BACKUP_NOTIFICATION_MAIL_TO="${MAIL_FROM_ADDRESS}"
BACKUP_ARCHIVE_PASSWORD=

BACKUP_DATABASE_ENABLED=true
BACKUP_DATABASE_FREQUENCY=every_four_hours
BACKUP_DATABASE_TIME=00:15

BACKUP_FULL_ENABLED=true
BACKUP_FULL_FREQUENCY=daily
BACKUP_FULL_TIME=01:00

BACKUP_ARCHIVE_ENABLED=true
BACKUP_ARCHIVE_FREQUENCY=weekly
BACKUP_ARCHIVE_DAY=sunday
BACKUP_ARCHIVE_TIME=02:00

VITE_APP_NAME="${APP_NAME}"
